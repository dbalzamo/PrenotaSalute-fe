# ⚙️ SERVICE

```typescript
@Injectable({ providedIn: 'root' })
export class UserService {
  private http = inject(HttpClient);
  private readonly BASE = '/api/v1/users';

  /**
   * Recupera la lista paginata degli utenti.
   * @param params filtri opzionali
   * @returns Observable con pagina di utenti
   */
  getAll(params?: UserFilters): Observable<Page<UserSummary>> {
    return this.http.get<ApiResponse<Page<UserSummary>>>(this.BASE, {
      params: toHttpParams(params)
    }).pipe(
      map(r => r.data),
      catchError(handleHttpError)
    );
  }

  /**
   * Crea un nuovo utente.
   * @param request dati del nuovo utente
   * @returns Observable con utente creato
   * @throws ApiError in caso di validazione fallita o conflitto
   */
  create(request: CreateUserRequest): Observable<UserDetail> {
    return this.http.post<ApiResponse<UserDetail>>(this.BASE, request).pipe(
      map(r => r.data),
      catchError(handleHttpError)
    );
  }
}
```

### Regole service
- JSDoc su ogni metodo pubblico con `@param`, `@returns`, `@throws`.
- Ogni service espone solo `Observable<T>` — mai dati raw o subscription interne.
- Usa `handleHttpError` centralizzato — mai gestire gli errori HTTP inline.
- `BASE_URL` come campo `private readonly` — mai stringa ripetuta.

