# 📋 LOGGING E GESTIONE ERRORI

```typescript
// Error interceptor centralizzato — shared/http/error.interceptor.ts
export const errorInterceptor: HttpInterceptorFn = (req, next) => {
  return next(req).pipe(
    catchError((error: HttpErrorResponse) => {
      const message = error.error?.message ?? 'Errore di rete. Riprova.';

      // Notifica UX
      inject(NotificationService).error(message);

      // Log strutturato — mai console.log in produzione
      if (!environment.production) {
        console.error(`[HTTP ${error.status}] ${req.url}`, error);
      }

      return throwError(() => new ApiError(error.status, message, error.error?.code));
    })
  );
};

// Classe errore tipata
export class ApiError extends Error {
  constructor(
    public readonly status: number,
    message: string,
    public readonly code?: string
  ) {
    super(message);
  }
}
```

